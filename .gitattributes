# Auto-detect text files and normalize line endings to LF on commit,
# native line endings on checkout. Prevents cross-platform diff noise.
* text=auto eol=lf

# Explicit text files — always LF regardless of platform
*.py        text eol=lf
*.pyi       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.cfg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.qrc       text eol=lf
*.qss       text eol=lf
*.svg       text eol=lf
*.sh        text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# Windows-specific text files — always CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.iss       text eol=crlf

# Binary files — never attempt diff or line-ending normalization
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.pyd       binary
*.whl       binary
*.zip       binary
*.gz        binary
*.pdf       binary

# GitHub linguist — exclude generated/vendored files from language stats
resources/icons/** linguist-vendored=true
build/dist/** linguist-generated=true
deployment/** linguist-generated=true
