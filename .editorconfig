# EditorConfig — https://editorconfig.org
#
# Universal editor settings so every contributor (and every editor)
# produces consistently formatted files. Most modern editors read this
# file automatically. No plugin required for VS Code, PyCharm, Vim,
# Sublime, or Emacs.

root = true

# ─── Defaults ─────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ─── Python ───────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 100

# ─── Markdown ─────────────────────────────────────────────────────────
# Trailing spaces in Markdown can mean line break — don't trim.
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# ─── Config files ─────────────────────────────────────────────────────
[*.{yml,yaml,json,toml,cfg,ini}]
indent_size = 2

# ─── Windows-specific files ──────────────────────────────────────────
[*.{bat,cmd,ps1,iss}]
end_of_line = crlf

# ─── Makefiles — tabs required ────────────────────────────────────────
[Makefile]
indent_style = tab
